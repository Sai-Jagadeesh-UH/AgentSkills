# Dockerfile.uvicorn — Single Uvicorn process (development/light production)
# Best for: small to medium load, Container Apps, Cloud Run

FROM python:3.12-slim AS base

# Security: non-root user
RUN groupadd --system app && useradd --system --gid app app

WORKDIR /app

# Install uv for fast dependency installation
RUN pip install --no-cache-dir uv

# Layer cache: copy deps before code
COPY pyproject.toml uv.lock* requirements.txt* ./
RUN if [ -f uv.lock ]; then uv sync --frozen --no-dev; \
    else pip install --no-cache-dir -r requirements.txt; fi

# Copy application
COPY --chown=app:app app/ ./app/
COPY --chown=app:app alembic/ ./alembic/ 2>/dev/null || true
COPY --chown=app:app alembic.ini ./alembic.ini 2>/dev/null || true

USER app

EXPOSE 8000

HEALTHCHECK --interval=30s --timeout=10s --start-period=10s --retries=3 \
  CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:8000/health')" || exit 1

# Exec form required for proper SIGTERM handling and lifespan events
CMD ["uvicorn", "app.main:app", \
     "--host", "0.0.0.0", \
     "--port", "8000", \
     "--proxy-headers", \
     "--forwarded-allow-ips", "*", \
     "--no-access-log"]
